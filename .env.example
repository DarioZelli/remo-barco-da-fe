# Netlify Blobs — obrigatório em produção (obtido no painel Netlify)
BLOBS_SITE_ID=seu-site-id-aqui
BLOBS_TOKEN=seu-token-blobs-aqui

# Autenticação administrativa
ADMIN_TOKEN=troque-este-token-em-producao
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha-em-producao

# Duração da sessão admin em ms (padrão: 4h = 14400000)
ADMIN_SESSION_TTL_MS=14400000

# Email transacional (futuro)
# SENDGRID_API_KEY=
# EMAIL_FROM=contato@globalremo.com

# WhatsApp (futuro)
# WHATSAPP_API_KEY=
